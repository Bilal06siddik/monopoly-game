{
  "name": "monopoly-game",
  "version": "1.0.0",
  "description": "Real-time 3D multiplayer Monopoly-style board game",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "start:test": "node server.js",
    "test": "npm run test:unit",
    "test:unit": "node --test \"test/shared*.test.js\"",
    "test:integration": "node --test \"test/integration/**/*.test.js\"",
    "test:stress": "node --test \"test/stress/**/*.test.js\"",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:stress",
    "test:coverage": "c8 --check-coverage --lines 35 --functions 40 --branches 50 --statements 35 --reporter=text --reporter=lcov npm run test:all",
    "test:e2e": "playwright test",
    "test:ci": "npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "c8": "^10.1.3",
    "socket.io-client": "^4.8.1"
  }
}
